# =============================================================================
# DATABASE & STORAGE - Supabase  (https://supabase.com)
# =============================================================================
# Cukup satu project Supabase untuk Database (Postgres) + Storage.
# Buat project baru di Supabase Dashboard:
#   https://supabase.com/dashboard -> New project
# Setelah project siap, ambil:
#   - Connection string  -> Settings -> Database -> Connection string
#   - API keys           -> Settings -> API
#
# Supabase menyediakan dua mode koneksi Postgres:
#   - Pooled (Transaction mode, port 6543) -> dipakai runtime (DATABASE_URL)
#   - Direct (port 5432)                    -> dipakai prisma migrate / db push
#
# Pastikan menambahkan parameter berikut di akhir URL:
#   DATABASE_URL: ?pgbouncer=true&connection_limit=1
#   DIRECT_URL:   (tanpa parameter tambahan)
#
# Contoh format Supabase (ganti placeholder):
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres"

# =============================================================================
# STORAGE - Supabase Storage (project yang SAMA dengan DATABASE di atas)
# =============================================================================
# Kita pakai bucket Storage dari project Supabase yang sama. Bucket akan dibuat
# otomatis oleh aplikasi pada upload pertama.
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="<service-role-secret>"
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-key>"

# Nama bucket di Supabase Storage (default: documents).
SUPABASE_STORAGE_BUCKET="documents"

# =============================================================================
# APP
# =============================================================================
NEXT_PUBLIC_APP_URL="https://your-deploy-domain"
# Generate dengan: openssl rand -base64 48
JWT_SECRET="<random-long-string-min-32-chars>"

# =============================================================================
# Initial admin (digunakan oleh script seed: npm run db:seed)
# =============================================================================
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="ChangeMe!Strong123"
