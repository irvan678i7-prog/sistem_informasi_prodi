# =============================================================================
# DATABASE - Neon PostgreSQL  (https://neon.tech)
# =============================================================================
# Buat project baru di Neon -> dashboard akan menampilkan connection string.
# Neon menyediakan dua endpoint:
#   - Pooled connection (host diakhiri "-pooler") -> dipakai runtime
#   - Direct connection  (tanpa "-pooler")        -> dipakai migrate
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require&pgbouncer=true&connect_timeout=15"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/DBNAME?sslmode=require"

# =============================================================================
# STORAGE - Cloudflare R2 (S3-compatible, free 10 GB, no egress fee)
# =============================================================================
# Buat di: https://dash.cloudflare.com  -> R2  -> Create bucket
# Lalu buat API token: R2 -> Manage API Tokens -> Create User API Token
# Permission: Object Read & Write, Bucket: pilih bucket yang baru dibuat.

# Cloudflare account ID (R2 sidebar -> "Account ID")
R2_ACCOUNT_ID="<your-cloudflare-account-id>"
# API token credentials (muncul SEKALI saat create token, simpan baik-baik)
R2_ACCESS_KEY_ID="<r2-access-key-id>"
R2_SECRET_ACCESS_KEY="<r2-secret-access-key>"
# Nama bucket yang dipakai (mis. "sipro-documents")
R2_BUCKET_NAME="sipro-documents"
# Public base URL (tanpa trailing slash). Dua opsi:
#  1. r2.dev URL gratis (Bucket -> Settings -> Public Access -> Allow Access)
#     Contoh: https://pub-abc123.r2.dev
#  2. Custom domain yang kamu pasangkan ke bucket
R2_PUBLIC_BASE_URL="https://pub-xxxxxxxx.r2.dev"

# =============================================================================
# APP
# =============================================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Generate dengan: openssl rand -base64 48
JWT_SECRET="<random-long-string-min-32-chars>"

# =============================================================================
# Initial admin (digunakan oleh script seed: npm run db:seed)
# =============================================================================
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="ChangeMe!Strong123"
