# =============================================================================
# DATABASE - Neon PostgreSQL  (https://neon.tech)
# =============================================================================
# Buat project baru di Neon -> dashboard akan menampilkan connection string.
# Neon menyediakan dua endpoint:
#   - Pooled connection (port 5432, host diakhiri "-pooler") -> dipakai runtime
#   - Direct connection  (port 5432, tanpa "-pooler")        -> dipakai migrate
#
# Pastikan menambahkan parameter berikut di akhir URL:
#   ?sslmode=require                              (untuk DIRECT_URL)
#   ?sslmode=require&pgbouncer=true&connect_timeout=15 (untuk DATABASE_URL)
#
# Contoh format Neon (ganti placeholder):
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require&pgbouncer=true&connect_timeout=15"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/DBNAME?sslmode=require"

# =============================================================================
# STORAGE - Supabase Storage (project TERPISAH khusus aplikasi ini)
# =============================================================================
# Supabase free plan mengizinkan beberapa project gratis. Buat project Supabase
# BARU khusus app ini agar tidak tabrakan dengan aplikasi lain.
# Kita HANYA memakai fitur Storage-nya, bukan database/auth-nya.
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="<service-role-secret>"
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-key>"

# Nama bucket di Supabase Storage (default: documents). Bucket akan dibuat
# otomatis oleh aplikasi jika belum ada.
SUPABASE_STORAGE_BUCKET="documents"

# =============================================================================
# APP
# =============================================================================
NEXT_PUBLIC_APP_URL="https://your-deploy-domain"
# Generate dengan: openssl rand -base64 48
JWT_SECRET="<random-long-string-min-32-chars>"

# =============================================================================
# Initial admin (digunakan oleh script seed: npm run db:seed)
# =============================================================================
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="ChangeMe!Strong123"
